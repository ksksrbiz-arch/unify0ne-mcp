# ─────────────────────────────────────────────────────────────────────────────
# UnifyOne MCP Server — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API Configuration ────────────────────────────────────────────────

# URL of the UnifyOne platform API (where this MCP server fetches data from)
# Default points to the production platform API
ONECOMMERCE_API_URL=https://1commerce.online/api

# API key for authenticating with the UnifyOne backend API
# Required for all API calls to the platform
ONECOMMERCE_API_KEY=your_backend_api_key_here

# ── MCP Server Authentication ────────────────────────────────────────────────

# API key for authenticating inbound requests TO this MCP server
# The UnifyOne platform sends this key in the Authorization header
# Generate a secure random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to disable authentication (NOT recommended for production)
MCP_API_KEY=your_mcp_server_api_key_here

